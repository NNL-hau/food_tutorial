@page "/admin/payments"
@layout AdminLayout
@inherits AuthorizedPageBase
@inject IPaymentApiService PaymentService
@using Food.Web.Models

<div class="admin-payments">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 style="font-weight: 800; color: var(--text-main); font-size: 2rem; margin: 0;">Lịch sử Thanh toán</h2>
            <p style="color: var(--text-muted); margin: 0;">Quản lý các giao dịch và trạng thái thanh toán từ khách hàng</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="glass-card p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Đang tải lịch sử giao dịch...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        <div class="glass-card p-4">
            <div class="table-container">
                <table class="table-fashion">
                    <thead>
                        <tr>
                            <th>Mã giao dịch</th>
                            <th>Đơn hàng</th>
                            <th>Tên đăng nhập</th>
                            <th>Số tiền</th>
                            <th>Phương thức</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in transactions)
                        {
                            <tr>
                                <td><code style="color: var(--primary-color);">@t.Id.ToString().Substring(0, 8)</code></td>
                                <td><NavLink href="@($"/admin/orders")">#@t.OrderId.ToString().Substring(0, 8)</NavLink></td>
                                <td><div style="font-weight: 600;">@t.UserName</div></td>
                                <td><div style="font-weight: 700; color: var(--text-main);">@t.Amount.ToString("N0")₫</div></td>
                                <td>
                                    <span class="payment-method-tag">
                                        <i class="@GetPaymentIcon(t.PaymentMethod)"></i>
                                        @t.PaymentMethod
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @GetStatusClass(t.Status)">@TranslateStatus(t.Status)</span>
                                </td>
                                <td><div class="text-muted" style="font-size: 0.85rem;">@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div></td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!transactions.Any())
                {
                    <div class="text-center py-5">
                        <i class="fa-solid fa-receipt" style="font-size: 3rem; color: var(--text-muted);"></i>
                        <p class="mt-3 text-muted">Chưa có giao dịch nào được ghi nhận</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .payment-method-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #f8fafc;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        color: #475569;
    }

    .badge-success { background: #ecfdf5; color: #10b981; }
    .badge-warning { background: #fff7ed; color: #f97316; }
    .badge-danger { background: #fef2f2; color: #ef4444; }
</style>

@code {
    private List<TransactionDto> transactions = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        isLoading = true;
        try
        {
            transactions = await PaymentService.GetTransactionsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi tải dữ liệu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetPaymentLogo(string method)
    {
        return method.ToLower() switch
        {
            "momo" => "https://img.vietqr.io/image/momo.png",
            "vnpay" => "https://img.vietqr.io/image/vnpay.png",
            _ => "https://cdn-icons-png.flaticon.com/512/2489/2489756.png" // COD icon
        };
    }

    private string GetPaymentIcon(string method)
    {
        return method.ToLower() switch
        {
            "creditcard" => "fa-solid fa-credit-card",
            "paypal" => "fa-brands fa-paypal",
            "momo" => "fa-solid fa-mobile-screen",
            _ => "fa-solid fa-money-bill"
        };
    }

    private string GetStatusClass(string status)
    {
        return status.ToLower() switch
        {
            "completed" or "success" => "badge-success",
            "pending" => "badge-warning",
            "failed" => "badge-danger",
            _ => "badge-secondary"
        };
    }

    private string TranslateStatus(string status)
    {
        return status.ToLower() switch
        {
            "completed" => "Hoàn thành",
            "success" => "Thành công",
            "pending" => "Chờ xử lý",
            "failed" => "Thất bại",
            _ => status
        };
    }

    protected override bool RequireAdminRole => true;
}

