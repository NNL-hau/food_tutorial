@page "/product/{Id:guid}"
@using Food.Web.Models
@using Food.Web.Services
@using Food.Web.Helpers
@inject IProductApiService ProductService
@inject IBasketService BasketService
@inject IReviewApiService ReviewService
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="product-details-page">
    <div class="container">
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Đang tải thông tin món ăn...</p>
            </div>
        }
        else if (product == null)
        {
            <div class="error-state">
                <h2>Không tìm thấy món ăn này</h2>
                <button class="btn-back" @onclick="GoBack">Quay lại thực đơn</button>
            </div>
        }
        else
        {
            <div class="breadcrumb">
                <a @onclick="GoBack" class="back-link"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
                <span class="sep">/</span>
                <span>@product.Name</span>
            </div>

            <div class="details-grid">
                <div class="image-gallery">
                    <div class="main-banner">
                        <img src="@(productImages.Any() ? productImages[currentImageIndex] : "/images/placeholder-product.jpg")" alt="@product.Name" class="active-banner-img" />
                        
                        @if (productImages.Count > 1)
                        {
                            <button class="nav-btn prev" @onclick="PrevImage"><i class="fa-solid fa-chevron-left"></i></button>
                            <button class="nav-btn next" @onclick="NextImage"><i class="fa-solid fa-chevron-right"></i></button>
                            
                            <div class="banner-dots">
                                @for (int i = 0; i < productImages.Count; i++)
                                {
                                    int index = i;
                                    <span class="dot @(currentImageIndex == index ? "active" : "")" @onclick="() => currentImageIndex = index"></span>
                                }
                            </div>
                        }
                    </div>

                    @if (productImages.Count > 1)
                    {
                        <div class="thumbnail-list">
                            @foreach (var (img, index) in productImages.Select((value, i) => (value, i)))
                            {
                                <div class="thumb-item @(currentImageIndex == index ? "active" : "")" @onclick="() => currentImageIndex = index">
                                    <img src="@img" alt="thumbnail @index" />
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="product-info-panel">
                    <h1 class="p-name">@product.Name</h1>
                    <div class="p-price">@product.Price.ToString("N0") đ</div>

                    <div class="p-options">
                        @if (availableColors.Any())
                        {
                            <div class="option-group">
                                <label>Tùy chọn khác</label>
                                <div class="chips">
                                    @foreach (var color in availableColors)
                                    {
                                        <button class="chip @(selectedColor == color ? "active" : "")" 
                                                @onclick="() => selectedColor = color">
                                            @color
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @if (availableSizes.Any())
                        {
                            <div class="option-group">
                                <label>Kích cỡ / Phần ăn <span class="required">*</span></label>
                                <div class="chips">
                                    @foreach (var size in availableSizes)
                                    {
                                        <div class="chip-wrapper">
                                            <button class="chip @(selectedSize == size ? "active" : "")" 
                                                    @onclick="() => SelectSize(size)">
                                                @size
                                            </button>
                                            <div class="size-tooltip">@GetSizeRecommendation(size)</div>
                                        </div>
                                    }
                                </div>
                                @if (showSizeError && string.IsNullOrEmpty(selectedSize))
                                {
                                    <div class="field-error">Vui lòng chọn phần ăn!</div>
                                }
                                <div class="size-guide-accordion">
                                    <div class="accordion-header" @onclick="() => isSizeGuideOpen = !isSizeGuideOpen">
                                        <span>Thành phần & Dinh dưỡng</span>
                                        <i class="fa-solid fa-chevron-@(isSizeGuideOpen ? "up" : "down")"></i>
                                    </div>
                                    @if (isSizeGuideOpen)
                                    {
                                        <div class="accordion-content">
                                            <p class="small text-muted mb-3">Thông tin dinh dưỡng ước tính cho mỗi khẩu phần tiêu chuẩn:</p>
                                            <table class="size-table">
                                                <thead>
                                                    <tr>
                                                        <th>Thành phần</th>
                                                        <th>Định lượng</th>
                                                        <th>Calo</th>
                                                        <th>Ghi chú</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td>Chất đạm</td>
                                                        <td>25g - 35g</td>
                                                        <td>150 kcal</td>
                                                        <td>Từ thịt tươi</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Chất béo</td>
                                                        <td>10g - 15g</td>
                                                        <td>90 kcal</td>
                                                        <td>Ít dầu mỡ</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Tinh bột</td>
                                                        <td>45g - 60g</td>
                                                        <td>200 kcal</td>
                                                        <td>Gạo/Bún sạch</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Chất xơ</td>
                                                        <td>5g - 8g</td>
                                                        <td>30 kcal</td>
                                                        <td>Rau củ tươi</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="p-meta">
                        <div class="meta-row">
                            <span class="label">Trạng thái:</span>
                            <span class="value @(product.StockQuantity > 0 ? "in-stock" : "out-of-stock")">
                                @(product.StockQuantity > 0 ? "Còn hàng" : "Hết hàng")
                            </span>
                        </div>
                        <div class="meta-row">
                            <span class="label">Số lượng còn:</span>
                            <span class="value">@product.StockQuantity</span>
                        </div>
                        <div class="meta-row">
                            <span class="label">Đã bán:</span>
                            <span class="value">@product.SoldQuantity</span>
                        </div>
                    </div>


                    <div class="p-description">
                        <h3>Giới thiệu món ăn</h3>
                        <p>@(string.IsNullOrEmpty(product.Description) ? "Món ăn hương vị truyền thống, chế biến từ nguyên liệu tươi sạch mỗi ngày." : product.Description)</p>
                    </div>

                    <div class="actions">
                        <button class="btn-add-to-cart" @onclick="HandleAddToCart" disabled="@(product.StockQuantity == 0 || isAdding)">
                            @if (isAdding)
                            {
                                <i class="fa-solid fa-spinner fa-spin"></i>
                                <span>Đang thêm...</span>
                            }
                            else
                            {
                                <i class="fa-solid fa-cart-plus"></i>
                                <span>THÊM VÀO GIỎ ĐẶT MÓN</span>
                            }
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(message) && message != "AUTH_REQUIRED")
                    {
                        <div class="error-modal-overlay" @onclick="() => message = null">
                            <div class="error-modal-content animate__animated animate__zoomIn" @onclick:stopPropagation>
                                <div class="error-modal-header">
                                    <i class="fa-solid @(isError ? "fa-circle-exclamation text-danger" : "fa-circle-check text-success")"></i>
                                    <span>Thông báo</span>
                                    <button class="btn-close-modal" @onclick="() => message = null">✕</button>
                                </div>
                                <div class="error-modal-body text-center">
                                    <p>@message</p>
                                </div>
                                <div class="error-modal-footer">
                                    <button class="btn btn-dark w-100" @onclick="() => message = null">Đóng</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (showLoginModal)
                    {
                        <div class="auth-modal-overlay" @onclick="() => showLoginModal = false">
                            <div class="auth-modal" @onclick:stopPropagation>
                                <button class="close-modal" @onclick="() => showLoginModal = false">✕</button>
                                <div class="auth-modal-content">
                                    <div class="auth-icon">
                                        <i class="fa-solid fa-user-lock"></i>
                                    </div>
                                    <h2>Yêu cầu đăng nhập</h2>
                                    <p>Vui lòng đăng nhập để có thể thêm món ăn này vào giỏ hàng của bạn.</p>
                                    <div class="auth-modal-actions">
                                        <button class="btn-primary-auth" @onclick='() => Navigation.NavigateTo("/login")'>Đăng nhập ngay</button>
                                        <button class="btn-secondary-auth" @onclick="() => showLoginModal = false">Để sau</button>
                                    </div>
                                    <div class="auth-footer">
                                        Chưa có tài khoản? <a href="/register">Đăng ký tại đây</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="extra-sections">
                <div class="reviews-section">
                    <div class="section-header">
                        <h2>Đánh giá từ thực khách (@reviews.Count)</h2>
                        <div class="avg-rating">
                            @if (reviews.Any())
                            {
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa-solid fa-star @(i <= Math.Round(reviews.Average(r => r.Rating)) ? "filled" : "")"></i>
                                    }
                                </div>
                                <span class="rating-val">@reviews.Average(r => r.Rating).ToString("0.0")/5</span>
                            }
                        </div>
                    </div>

                    @* ===== REVIEW FORM ===== *@
                    @if (isLoggedIn)
                    {
                        <div class="review-form-card">
                            <h3><i class="fa-solid fa-pen-to-square me-2"></i>Chia sẻ cảm nhận của bạn</h3>
                            <div class="star-picker">
                                <span>Hương vị món ăn:</span>
                                <div class="stars-input">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        int starVal = i;
                                        <span class="star-opt @(newReviewRating >= starVal ? "selected" : "")" 
                                              @onclick="() => newReviewRating = starVal"
                                              @onmouseover="() => hoverRating = starVal"
                                              @onmouseout="() => hoverRating = 0">
                                            <i class="fa-solid fa-star"></i>
                                        </span>
                                    }
                                </div>
                                @if (newReviewRating > 0)
                                {
                                    <span class="star-label">@GetRatingLabel(newReviewRating)</span>
                                }
                            </div>
                            <textarea class="review-textarea" 
                                      @bind="newReviewComment"
                                      placeholder="Món ăn có hợp khẩu vị bạn không? Hãy chia sẻ nhé..."
                                      rows="4"
                                      maxlength="1000"></textarea>
                            @if (!string.IsNullOrEmpty(reviewError))
                            {
                                <div class="review-error">
                                    <i class="fa-solid fa-triangle-exclamation me-1"></i>@reviewError
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(reviewSuccess))
                            {
                                <div class="review-success">
                                    <i class="fa-solid fa-circle-check me-1"></i>@reviewSuccess
                                </div>
                            }
                            <div class="review-form-actions">
                                <span class="char-count">@(newReviewComment?.Length ?? 0)/1000 ký tự</span>
                                <button class="btn-submit-review" @onclick="SubmitReview" disabled="@isSubmittingReview">
                                    @if (isSubmittingReview)
                                    {
                                        <i class="fa-solid fa-spinner fa-spin"></i>
                                        <span>Đang gửi...</span>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-paper-plane"></i>
                                        <span>Gửi đánh giá</span>
                                    }
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="login-to-review">
                            <i class="fa-solid fa-lock"></i>
                            <span><a href="/login">Đăng nhập</a> để viết đánh giá của bạn</span>
                        </div>
                    }

                    @* ===== REVIEWS LIST ===== *@
                    @if (!reviews.Any())
                    {
                        <p class="no-reviews">Chưa có đánh giá nào cho món ăn này.</p>
                    }
                    else
                    {
                        <div class="reviews-list">
                            @foreach (var review in reviews.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="review-item">
                                    <div class="review-avatar">
                                        @review.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="review-body">
                                        <div class="review-meta">
                                            <span class="reviewer">@review.UserName</span>
                                            <span class="review-date">@review.CreatedAt.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="review-rating">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fa-solid fa-star @(i <= review.Rating ? "filled" : "")"></i>
                                            }
                                            <span class="rating-text">@GetRatingLabel(review.Rating)</span>
                                        </div>
                                        <p class="review-comment">@review.Comment</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="related-products-section">
                    <div class="section-header">
                        <h2>Món ăn tương tự</h2>
                    </div>
                    @if (relatedProducts.Any())
                    {
                        <div class="products-grid">
                            @foreach (var rp in relatedProducts)
                            {
                                <div class="p-card" @onclick="() => NavigateToProduct(rp.Id)">
                                    <div class="p-image">
                                        <img src="@ProductHelpers.GetFirstImageUrl(rp.ImageUrl)" alt="@rp.Name" />
                                    </div>
                                    <div class="p-details">
                                        <h3 class="rp-name">@rp.Name</h3>
                                        <div class="rp-price">@rp.Price.ToString("N0") đ</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p>Không có món ăn tương tự.</p>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    
    private ProductDto? product;
    private List<string> availableColors = new();
    private List<string> availableSizes = new();
    private List<ReviewDto> reviews = new();
    private List<ProductDto> relatedProducts = new();
    private List<string> productImages = new();
    private int currentImageIndex = 0;
    private string? selectedColor;
    private string? selectedSize;
    private bool isLoading = true;
    private bool isAdding = false;
    private string? message;
    private bool isError = false;
    private bool showSizeError = false;
    private bool isSizeGuideOpen = false;
    private bool showLoginModal = false;

    // Review state
    private bool isLoggedIn = false;
    private int newReviewRating = 0;
    private int hoverRating = 0;
    private string? newReviewComment;
    private string? reviewError;
    private string? reviewSuccess;
    private bool isSubmittingReview = false;

    protected override async Task OnParametersSetAsync()
    {
        isLoggedIn = await AuthService.IsAuthenticatedAsync();
        await LoadProduct();
    }

    private async Task LoadProduct()
    {
        isLoading = true;
        message = null;
        selectedSize = null;
        showSizeError = false;
        try
        {
            product = await ProductService.GetProductAsync(Id);
            if (product != null)
            {
                if (string.IsNullOrEmpty(product.Sizes))
                {
                    product = product with { Sizes = "S, M, L, XL, XXL" };
                }

                if (string.IsNullOrEmpty(product.Colors))
                {
                    product = product with { Colors = "Vàng, Trắng, Đen, Đỏ, Xanh" };
                }
                
                availableColors = (product.Colors ?? "").Split(',').Select(c => c.Trim()).Where(c => !string.IsNullOrEmpty(c)).ToList();
                availableSizes = product.Sizes.Split(',').Select(s => s.Trim()).Where(s => !string.IsNullOrEmpty(s)).ToList();

                // Prepare images for carousel
                productImages = (product.ImageUrl ?? "").Split(',').Select(i => i.Trim()).Where(i => !string.IsNullOrEmpty(i)).ToList();
                if (!productImages.Any()) productImages.Add("/images/placeholder-product.jpg");
                
                // For demonstration purposes, if only one image, let's add placeholders to show banner functionality
                if (productImages.Count == 1 && !string.IsNullOrEmpty(product.ImageUrl))
                {
                    // Add some dummy variant images to simulate a gallery if it's a real image
                    if (!product.ImageUrl.Contains("placeholder"))
                    {
                         productImages.Add(product.ImageUrl); // Repeat same for demo
                         productImages.Add(product.ImageUrl);
                    }
                }
                
                currentImageIndex = 0;
                selectedColor = availableColors.FirstOrDefault();
                // selectedSize remains null to force selection
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
        
        // Load secondary data after main product data is shown
        _ = LoadSecondaryDataAsync();
    }

    private async Task LoadSecondaryDataAsync()
    {
        try
        {
            var reviewTask = ReviewService.GetReviewsByProductIdAsync(Id);
            var relatedTask = ProductService.GetRelatedProductsAsync(Id);
            await Task.WhenAll(reviewTask, relatedTask);
            reviews = await reviewTask;
            relatedProducts = await relatedTask;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading secondary data: {ex.Message}");
        }
    }

    private async Task HandleAddToCart()
    {
        if (product == null) return;
        
        message = null;
        isError = false;

        if (string.IsNullOrEmpty(selectedSize))
        {
            showSizeError = true;
            message = "Vui lòng chọn kích cỡ!";
            isError = true;
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            showLoginModal = true;
            return;
        }

        isAdding = true;
        try
        {
            // We need to pass the selected options. 
            // Since AddToBasketAsync only takes ProductDto, we might need a workaround 
            // or update the service. But for now, we'll set the options on the DTO or use a new method if we had one.
            // Actually, BasketService.AddToBasketAsync uses default options. 
            // Let's use UpdateQuantityAsync after adding if needed, or update AddToBasketAsync.
            
            // For now, let's update a temporary version of the product with selected options 
            // if our service supports it, but it doesn't. 
            // Let's call AddToBasket and then immediately update options if they differ from default.
            
            await BasketService.AddToBasketAsync(product, selectedColor, selectedSize);
            
            message = "Đã thêm vào giỏ hàng thành công!";
        }
        catch (Exception ex)
        {
            message = $"Lỗi: {ex.Message}";
            isError = true;
        }
        finally
        {
            isAdding = false;
        }
    }

    private void SelectSize(string size)
    {
        selectedSize = size;
        showSizeError = false;
        if (message == "Vui lòng chọn kích cỡ!") message = null;
    }

    private async Task SubmitReview()
    {
        reviewError = null;
        reviewSuccess = null;

        if (newReviewRating == 0)
        {
            reviewError = "Vui lòng chọn số sao đánh giá.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newReviewComment) || newReviewComment.Trim().Length < 5)
        {
            reviewError = "Vui lòng nhập nhận xét ít nhất 5 ký tự.";
            return;
        }

        isSubmittingReview = true;
        try
        {
            var userName = await AuthService.GetUserNameAsync();
            var review = new ReviewDto(
                Guid.NewGuid(),
                Id,
                userName ?? "Khách hàng",
                newReviewRating,
                newReviewComment.Trim(),
                DateTime.Now,
                false
            );

            var success = await ReviewService.CreateReviewAsync(review);
            if (success)
            {
                reviewSuccess = "Cảm ơn bạn đã đánh giá!";
                newReviewRating = 0;
                newReviewComment = null;
                // Reload reviews to reflect any approved ones
                reviews = await ReviewService.GetReviewsByProductIdAsync(Id);
            }
            else
            {
                reviewError = "Không thể gửi đánh giá. Vui lòng thử lại sau.";
            }
        }
        catch
        {
            reviewError = "Đã xảy ra lỗi. Vui lòng thử lại sau.";
        }
        finally
        {
            isSubmittingReview = false;
        }
    }

    private string GetRatingLabel(int rating) => rating switch
    {
        1 => "Rất tệ",
        2 => "Tệ",
        3 => "Bình thường",
        4 => "Tốt",
        5 => "Xuất sắc",
        _ => ""
    };

    private void NextImage() => currentImageIndex = (currentImageIndex + 1) % productImages.Count;
    private void PrevImage() => currentImageIndex = (currentImageIndex - 1 + productImages.Count) % productImages.Count;

    private string GetSizeRecommendation(string size)
    {
        return size.ToUpper() switch
        {
            "S" => "Phần nhỏ: Phù hợp cho 1 trẻ em hoặc ăn nhẹ",
            "M" => "Phần vừa: Khẩu phần tiêu chuẩn cho 1 người lớn",
            "L" => "Phần lớn: Cho người có sức ăn tốt hoặc dùng chung",
            "XL" => "Tô khổng lồ: Thử thách sức ăn hoặc cho 2 người",
            "XXL" => "Phần gia đình: Phù hợp cho nhóm 3-4 người",
            _ => "Vui lòng liên hệ nhân viên để được tư vấn"
        };
    }

    private void NavigateToProduct(Guid id) => Navigation.NavigateTo($"/product/{id}");
    private void GoBack() => Navigation.NavigateTo("/");
}

<style>
    .product-details-page {
        padding: 40px 0;
        background: #f8f9fa;
        min-height: 80vh;
    }
    
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .breadcrumb {
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #666;
        font-size: 14px;
    }

    .back-link {
        cursor: pointer;
        color: #2F4858;
        font-weight: 600;
        text-decoration: none;
    }

    .back-link:hover {
        text-decoration: underline;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .image-gallery {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .main-banner {
        position: relative;
        width: 100%;
        aspect-ratio: 4/5;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        background: #eee;
    }

    .active-banner-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.4s ease-in-out;
    }

    .nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,0.8);
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
