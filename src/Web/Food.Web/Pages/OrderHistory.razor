@page "/order-history"
@inherits AuthorizedPageBase
@inject IOrderApiService OrderService
@using Food.Web.Models
@using Food.Web.Services

<div class="order-history-container">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 style="font-weight: 800; color: var(--text-main); font-size: 2rem; margin: 0;">Lịch sử đặt món</h2>
            <p style="color: var(--text-muted); margin: 0;">Theo dõi các đơn đặt món của bạn</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="glass-card p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Đang tải danh sách đơn hàng...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            @errorMessage
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadOrders">Thử lại</button>
        </div>
    }
    else
    {
        <div class="glass-card p-4">
            <div class="table-container">
                <table class="table-fashion">
                    <thead>
                        <tr>
                            <th>Mã đơn món</th>
                            <th>Ngày đặt</th>
                            <th>Món ăn</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in orders)
                        {
                            <tr>
                                <td><strong style="color: var(--primary-color);">#@o.Id.ToString().Substring(0, 8).ToUpper()</strong></td>
                                <td>
                                    <div style="color: var(--text-main); font-weight: 500;">@o.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div style="font-size: 0.8rem; color: var(--text-muted);">@o.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    @if(o.OrderItems != null && o.OrderItems.Any())
                                    {
                                        <div class="text-truncate" style="max-width: 200px;" title="@string.Join(", ", o.OrderItems.Select(i => i.ProductName))">
                                            @o.OrderItems.First().ProductName
                                            @if (o.OrderItems.Count > 1)
                                            {
                                                <span class="text-muted" style="font-size: 0.8rem;"> (và @(o.OrderItems.Count - 1) món khác)</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="price-cell">@o.TotalPrice.ToString("N0") ₫</td>
                                <td>
                                    <span class="status-badge-order" style="background: @GetStatusBg(o.OrderStatus); color: @GetStatusColor(o.OrderStatus);">
                                        @TranslateStatus(o.OrderStatus)
                                    </span>
                                </td>
                                <td>
                                    <div class="action-buttons justify-content-center gap-2">
                                        <button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1 action-btn-fashion" title="Xem chi tiết" @onclick="() => ShowOrderDetails(o)">
                                            <i class="fa-solid fa-eye"></i> Chi tiết
                                        </button>
                                        @if (o.OrderStatus == "InProgress" || o.OrderStatus == "Shipped" || o.OrderStatus == "Delivered")
                                        {
                                            <a href="/order-tracking/@o.Id" class="btn btn-sm btn-outline-success d-flex align-items-center gap-1 action-btn-fashion" title="Theo dõi">
                                                <i class="fa-solid fa-location-dot"></i> Theo dõi
                                            </a>
                                        }
                                        @if (o.OrderStatus == "AwaitingPayment" || o.OrderStatus == "Pending")
                                        {
                                            <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1 action-btn-fashion" title="Hủy đơn hàng" @onclick="() => ShowCancelModal(o)">
                                                <i class="fa-solid fa-ban"></i> Hủy đơn
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!orders.Any())
                {
                    <div class="text-center py-5">
                        <i class="fa-solid fa-box-open" style="font-size: 3rem; color: var(--text-muted);"></i>
                        <p class="mt-3 text-muted">Bạn chưa có đơn đặt món nào.</p>
                        <a href="/" class="btn btn-primary mt-3">Khám phá thực đơn</a>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Order Details Modal *@
@if (showDetailsModal && selectedOrder != null)
{
    <div class="modal-overlay" @onclick="CloseDetailsModal">
        <div class="modal-dialog-custom large" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <h4><i class="fa-solid fa-receipt me-2"></i>Chi tiết đơn món #@selectedOrder.Id.ToString().Substring(0, 8).ToUpper()</h4>
                <button class="btn-close-custom" @onclick="CloseDetailsModal">&times;</button>
            </div>
            <div class="modal-body-custom">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Người nhận</h6>
                        <p class="mb-0"><strong>@selectedOrder.FullName</strong></p>
                        <p class="mb-0">SĐT: @selectedOrder.PhoneNumber</p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Địa chỉ giao hàng</h6>
                        <p class="mb-0">@selectedOrder.AddressDetail, @selectedOrder.Ward, @selectedOrder.District, @selectedOrder.Province</p>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Thông tin thanh toán</h6>
                        <p class="mb-0"><strong>@selectedOrder.PaymentMethodName</strong></p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Trạng thái</h6>
                         <span class="status-badge-order" style="background: @GetStatusBg(selectedOrder.OrderStatus); color: @GetStatusColor(selectedOrder.OrderStatus);">
                            @TranslateStatus(selectedOrder.OrderStatus)
                        </span>
                    </div>
                </div>

                <h6 class="text-muted mb-3">Món ăn đã chọn</h6>
                <div class="order-items">
                    @foreach (var item in selectedOrder.OrderItems)
                    {
                        <div class="order-item-row">
                            <div>
                                <strong>@item.ProductName</strong>
                                <div class="text-muted small">Số lượng: @item.Quantity</div>
                            </div>
                            <div class="text-end">
                                <strong>@item.Price.ToString("N0") ₫</strong>
                            </div>
                        </div>
                    }
                </div>

                @if (selectedOrder.CouponAmount > 0)
                {
                    <div class="order-total" style="padding-top: 10px; padding-bottom: 5px; border-top: 1px dashed #eee;">
                        <span>Mã giảm giá (@selectedOrder.CouponCode):</span>
                        <strong class="text-danger">-@selectedOrder.CouponAmount.ToString("N0") ₫</strong>
                    </div>
                }

                <div class="order-total" style='border-top: @(selectedOrder.CouponAmount > 0 ? "none" : "2px solid #f0f0f0")'>
                    <strong>Tổng cộng:</strong>
                    <strong class="text-primary">@selectedOrder.TotalPrice.ToString("N0") ₫</strong>
                </div>
            </div>
            <div class="modal-footer-custom justify-content-between">
                <div>
                     @if (selectedOrder.OrderStatus == "AwaitingPayment" || selectedOrder.OrderStatus == "Pending")
                    {
                        <button class="btn btn-outline-danger" @onclick="() => { CloseDetailsModal(); ShowCancelModal(selectedOrder); }">
                            <i class="fa-solid fa-ban me-2"></i> Hủy đơn đặt món
                        </button>
                    }
                </div>
                <button class="btn btn-secondary-custom" @onclick="CloseDetailsModal">Đóng</button>
            </div>
        </div>
    </div>
}

@* Cancel Order Modal *@
@if (showCancelModal && orderToCancel != null)
{
    <div class="modal-overlay" @onclick="CloseCancelModal">
        <div class="modal-dialog-custom" @onclick:stopPropagation>
            <div class="modal-header-custom" style="background: #fff0f0; border-bottom-color: #ffe0e0;">
                <h4 style="color: #dc3545;"><i class="fa-solid fa-triangle-exclamation me-2"></i>Xác nhận hủy đơn món</h4>
                <button class="btn-close-custom" @onclick="CloseCancelModal">&times;</button>
            </div>
            <div class="modal-body-custom">
                <p>Bạn có chắc chắn muốn hủy đơn hàng <strong>#@orderToCancel.Id.ToString().Substring(0, 8).ToUpper()</strong> không?</p>
                <p class="text-muted small">Lưu ý: Hành động này không thể hoàn tác.</p>
                
                @if (!string.IsNullOrEmpty(statusError))
                {
                    <div class="alert alert-danger mt-3">@statusError</div>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-secondary-custom" @onclick="CloseCancelModal">Không</button>
                <button class="btn btn-danger" style="padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 600;" @onclick="CancelOrder" disabled="@isUpdating">
                    @if (isUpdating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Đồng ý hủy
                </button>
            </div>
        </div>
    </div>
}

<style>
    .order-history-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }
    
    .status-badge-order {
        padding: 0.4rem 1rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.8rem;
        white-space: nowrap;
        display: inline-block;
    }

    .order-items {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .order-item-row {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .order-item-row:last-child {
        border-bottom: none;
    }

    .order-total {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 12px;
        font-size: 1.1rem;
    }

    .modal-dialog-custom.large {
        max-width: 700px;
    }

    /* Action Buttons Styles */
    .action-btn-fashion {
        border-radius: 20px;
        padding: 0.35rem 1rem;
        font-weight: 500;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        border-width: 1.5px;
    }

    .action-btn-fashion.btn-outline-primary {
        color: var(--primary-color, #4f46e5);
        border-color: var(--primary-color, #4f46e5);
    }
    .action-btn-fashion.btn-outline-primary:hover {
        background-color: var(--primary-color, #4f46e5);
        color: #fff;
        box-shadow: 0 4px 10px rgba(79, 70, 229, 0.2);
        transform: translateY(-1px);
    }

    .action-btn-fashion.btn-outline-danger {
        color: #ef4444;
        border-color: #ef4444;
    }
    .action-btn-fashion.btn-outline-danger:hover {
        background-color: #ef4444;
        color: #fff;
        box-shadow: 0 4px 10px rgba(239, 68, 68, 0.2);
        transform: translateY(-1px);
    }

    .action-btn-fashion.btn-outline-success {
        color: #10b981;
        border-color: #10b981;
    }
    .action-btn-fashion.btn-outline-success:hover {
        background-color: #10b981;
        color: #fff;
        box-shadow: 0 4px 10px rgba(16, 185, 129, 0.2);
        transform: translateY(-1px);
    }
</style>

@code {
    private List<OrderDto> orders = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    // Order details modal
    private bool showDetailsModal = false;
    private OrderDto? selectedOrder = null;

    // Cancel modal
    private bool showCancelModal = false;
    private bool isUpdating = false;
    private string statusError = string.Empty;
    private OrderDto? orderToCancel = null;

    protected override bool RequireAdminRole => false; // User page

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user == null || string.IsNullOrEmpty(user.Email))
            {
                errorMessage = "Không tìm thấy thông tin người dùng.";
                return;
            }

            Console.WriteLine($"[OrderHistory] Loading orders for {user.Email}");
            var fetchedOrders = await OrderService.GetOrdersAsync(user.Email);
            if (fetchedOrders != null)
            {
                orders = fetchedOrders.OrderByDescending(o => o.CreatedAt).ToList();
            }
            else
            {
                orders = new List<OrderDto>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi tải danh sách đơn hàng: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string TranslateStatus(string status) => status switch
    {
        "AwaitingPayment" => "Chờ thanh toán",
        "Pending" => "Chờ xác nhận",
        "InProgress" => "Đang chuẩn bị món",
        "Shipped" => "Đã giao món",
        "Cancelled" => "Đã hủy",
        _ => status
    };

    private string GetStatusBg(string status) => status switch
    {
        "Shipped" => "#ecfdf5",
        "AwaitingPayment" => "#fef2f2",
        "Pending" => "#fffbeb",
        "InProgress" => "#eff6ff",
        "Cancelled" => "#f3f4f6",
        _ => "#f1f3f9"
    };

    private string GetStatusColor(string status) => status switch
    {
        "Shipped" => "#059669",
        "AwaitingPayment" => "#ef4444",
        "Pending" => "#d97706",
        "InProgress" => "#2563eb",
        "Cancelled" => "#9ca3af",
        _ => "#64748b"
    };

    private void ShowOrderDetails(OrderDto order)
    {
        selectedOrder = order;
        showDetailsModal = true;
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedOrder = null;
    }

    private void ShowCancelModal(OrderDto order)
    {
        orderToCancel = order;
        statusError = string.Empty;
        showCancelModal = true;
    }

    private void CloseCancelModal()
    {
        showCancelModal = false;
        orderToCancel = null;
        statusError = string.Empty;
    }

    private async Task CancelOrder()
    {
        if (orderToCancel == null) return;

        isUpdating = true;
        statusError = string.Empty;

        try
        {
            var success = await OrderService.UpdateOrderStatusAsync(orderToCancel.Id, "Cancelled");
            if (success)
            {
                await LoadOrders();
                CloseCancelModal();
            }
            else
            {
                statusError = "Lỗi hủy đơn hàng. Vui lòng thử lại sau.";
            }
        }
        catch (Exception ex)
        {
            statusError = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }
}
