@page "/admin/users"
@layout AdminLayout
@inherits AuthorizedPageBase
@inject IUserApiService UserService
@using Food.Web.Models

<PageTitle>Khách Hàng - FoodOrder Admin</PageTitle>

<div class="admin-users">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 style="font-weight: 800; color: var(--text-main); font-size: 2rem; margin: 0;"><i class="fa-solid fa-users me-2" style="color: #FF6B35;"></i>Khách Hàng</h2>
            <p style="color: var(--text-muted); margin: 0;">Quản lý thông tin và quyền hạn khách hàng</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="glass-card p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Đang tải danh sách người dùng...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            @errorMessage
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadUsers">Thử lại</button>
        </div>
    }
    else
    {
        <div class="glass-card p-4">
            <div class="d-flex gap-3 mb-4">
                <div class="search-box-premium" style="flex: 1;">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                    <input type="text" placeholder="Tìm tên, email..." @bind-value="searchTerm" @bind-value:event="oninput" />
                </div>
            </div>

            <div class="table-container">
                <table class="table-fashion">
                    <thead>
                        <tr>
                             <th>Tên đăng nhập</th>
                            <th>Email</th>
                            <th>Vai trò</th>
                            <th>Ngày tham gia</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in FilteredUsers)
                        {
                            <tr>
                                <td>
                                     <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-premium" style="background: @GetAvatarBg(u.Role);">
                                            @(string.IsNullOrEmpty(u.Email) ? "?" : u.Email.Substring(0, 1).ToUpper())
                                        </div>
                                        <div style="font-weight: 700; color: var(--text-main);">@u.Email</div>
                                    </div>
                                </td>
                                <td><span style="color: var(--text-muted);">@u.Email</span></td>
                                <td>
                                    <select class="role-select @GetRoleBadgeClass(u.Role)" value="@u.Role" @onchange="e => UpdateRole(u.Id, e.Value?.ToString() ?? u.Role)">
                                        <option value="Customer">Khách hàng</option>
                                        <option value="Admin">Admin</option>
                                    </select>
                                </td>
                                <td>
                                    <div style="color: var(--text-main); font-weight: 500;">@u.CreatedAt.ToString("dd/MM/yyyy")</div>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-action delete" title="Xóa tài khoản" @onclick="() => ConfirmDelete(u)">
                                            <i class="fa-solid fa-user-slash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!FilteredUsers.Any())
                {
                    <div class="text-center py-5">
                        <i class="fa-solid fa-users" style="font-size: 3rem; color: var(--text-muted);"></i>
                        <p class="mt-3 text-muted">Không tìm thấy người dùng nào</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Delete Confirmation *@
@if (showDeleteConfirm && userToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-dialog-custom confirm-dialog" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <h4><i class="fa-solid fa-user-slash me-2 text-danger"></i>Xác nhận xóa</h4>
                <button class="btn-close-custom" @onclick="CancelDelete">&times;</button>
            </div>
            <div class="modal-body-custom">
                <p>Bạn có chắc chắn muốn xóa tài khoản <strong>@userToDelete.FullName</strong>?</p>
                <p class="text-muted">Hành động này không thể hoàn tác.</p>
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-secondary-custom" @onclick="CancelDelete">Hủy</button>
                <button class="btn btn-danger-custom" @onclick="DeleteUser" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Xóa
                </button>
            </div>
        </div>
    </div>
}

<style>
    .avatar-premium {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .role-select {
        padding: 0.5rem 1.2rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.85rem;
        border: 1px solid;
        cursor: pointer;
        transition: var(--transition);
    }

    .role-select.badge-admin {
        background: #fef2f2;
        color: #dc2626;
        border-color: #fee2e2;
    }

    .role-select.badge-user {
        background: #f0fdf4;
        color: #16a34a;
        border-color: #dcfce7;
    }

    .role-select:hover {
        filter: brightness(0.95);
    }

    .search-box-premium {
        background: #f1f3f9;
        border-radius: 14px;
        padding: 0.8rem 1.2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .search-box-premium input {
        border: none;
        outline: none;
        background: transparent;
        width: 100%;
    }
</style>

@code {
    private List<UserDto> users = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string searchTerm = string.Empty;

    // Delete confirmation
    private bool showDeleteConfirm = false;
    private bool isDeleting = false;
    private UserDto? userToDelete = null;

    private IEnumerable<UserDto> FilteredUsers
    {
        get
        {
            var filtered = users.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                filtered = filtered.Where(u =>
                    u.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    u.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
            }

            return filtered.OrderByDescending(u => u.CreatedAt);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            users = await UserService.GetUsersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi tải danh sách người dùng: {ex.Message}. Đảm bảo bạn đã đăng nhập với quyền Admin.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetAvatarBg(string role) => role == "Admin" ? "#6b46c1" : "#a29bfe";

    private string GetRoleBadgeClass(string role) => role == "Admin" ? "badge-admin" : "badge-user";

    private async Task UpdateRole(Guid userId, string newRole)
    {
        try
        {
            var success = await UserService.UpdateUserRoleAsync(userId, newRole);
            if (success)
            {
                await LoadUsers();
            }
            else
            {
                errorMessage = "Lỗi cập nhật vai trò";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
    }

    private void ConfirmDelete(UserDto user)
    {
        userToDelete = user;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        userToDelete = null;
    }

    private async Task DeleteUser()
    {
        if (userToDelete == null) return;

        isDeleting = true;
        try
        {
            var success = await UserService.DeleteUserAsync(userToDelete.Id);
            if (success)
            {
                await LoadUsers();
                CancelDelete();
            }
            else
            {
                errorMessage = "Lỗi xóa người dùng";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    protected override bool RequireAdminRole => true;
}
