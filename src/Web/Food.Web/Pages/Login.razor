@page "/login"
@page "/register"
@layout EmptyLayout
@using Food.Web.Models
@using Food.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-container @(isSignUp ? "right-panel-active" : "")">
    <!-- Sign Up Form -->
    <div class="form-container sign-up-container">
        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" OnInvalidSubmit="() => isRegisterSubmitted = true" class="@(isRegisterSubmitted ? "submitted" : "")">
            <DataAnnotationsValidator />
            <h1>Tạo tài khoản</h1>
            <p class="subtitle">hoặc sử dụng tên đăng nhập để đăng ký:</p>
            
            <div class="input-wrapper">
                <InputText @bind-Value="registerModel.FullName" placeholder="Tên đăng nhập (Bắt buộc)" />
                <div class="validation-error"><ValidationMessage For="@(() => registerModel.FullName)" /></div>
            </div>

            <div class="input-wrapper">
                <InputText @bind-Value="registerModel.Email" placeholder="Email (Bắt buộc)" />
                <div class="validation-error"><ValidationMessage For="@(() => registerModel.Email)" /></div>
            </div>

            <div class="input-wrapper">
                <InputText @bind-Value="registerModel.Address" placeholder="Địa chỉ (Tùy chọn)" />
            </div>

            <div class="input-wrapper">
                <InputText @bind-Value="registerModel.PhoneNumber" placeholder="Số điện thoại (Tùy chọn)" />
            </div>

            <div class="input-wrapper">
                <InputText type="password" @bind-Value="registerModel.Password" placeholder="Mật khẩu (Bắt buộc)" />
                <div class="validation-error"><ValidationMessage For="@(() => registerModel.Password)" /></div>
            </div>

            <div class="input-wrapper">
                <InputText type="password" @bind-Value="registerModel.ConfirmPassword" placeholder="Xác nhận mật khẩu" />
                <div class="validation-error"><ValidationMessage For="@(() => registerModel.ConfirmPassword)" /></div>
            </div>

            <button type="submit" @onclick="() => isRegisterSubmitted = true">ĐĂNG KÝ</button>
            
            @if (!string.IsNullOrEmpty(registerError))
            {
                <div class="error-msg">@registerError</div>
            }
        </EditForm>
    </div>

    <!-- Sign In Form -->
    <div class="form-container sign-in-container">
        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" OnInvalidSubmit="() => isLoginSubmitted = true" class="@(isLoginSubmitted ? "submitted" : "")">
            <DataAnnotationsValidator />
            <h1>Đăng nhập FoodOrder</h1>
            
            <div class="input-wrapper">
                <InputText @bind-Value="loginModel.UserIdentifier" placeholder="Tên đăng nhập (Bắt buộc)" />
                <div class="validation-error"><ValidationMessage For="@(() => loginModel.UserIdentifier)" /></div>
            </div>

            <div class="input-wrapper">
                <InputText type="password" @bind-Value="loginModel.Password" placeholder="Mật khẩu (Bắt buộc)" />
                <div class="validation-error"><ValidationMessage For="@(() => loginModel.Password)" /></div>
            </div>

            <button type="submit" class="signin-btn" @onclick="() => isLoginSubmitted = true">ĐĂNG NHẬP</button>
            
            <a href="javascript:void(0)" class="forgot-password-link" @onclick="OpenForgotPasswordModal">Quên mật khẩu?</a>
            
            <span class="or-divider">hoặc đăng nhập bằng</span>
            
            <div id="google-btn-container" style="margin-top: 15px; display: flex; justify-content: center;"></div>
            
            @if (!string.IsNullOrEmpty(loginError))
            {
                <div class="error-msg">@loginError</div>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-msg">@successMessage</div>
            }
        </EditForm>
    </div>

    <!-- Overlay -->
    <div class="overlay-container">
        <div class="overlay">
            <div class="overlay-panel overlay-left">
                <div class="overlay-image"></div>
                <h1>Mừng bạn quay lại!</h1>
                <p>Để duy trì kết nối với chúng tôi vui lòng đăng nhập bằng thông tin cá nhân của bạn</p>
                <button class="ghost" @onclick="TogglePanel">ĐĂNG NHẬP</button>
            </div>
            <div class="overlay-panel overlay-right">
                <div class="overlay-image"></div>
                <h1>Chào bạn mới!</h1>
                <p>Nhập thông tin cá nhân của bạn và bắt đầu hành trình với chúng tôi</p>
                <button class="ghost" @onclick="TogglePanel">ĐĂNG KÝ</button>
            </div>
        </div>
        
        <!-- Fireworks effect container -->
        <div class="fireworks-container">
            @for (int i = 0; i < 5; i++)
            {
                <div class="firework-burst">
                    @for (int j = 0; j < 12; j++)
                    {
                        <div class="spark"></div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Forgot Password Modal -->
@if (showForgotPassword)
{
    <div class="forgot-password-overlay" @onclick="CloseForgotPasswordModal">
        <div class="forgot-password-modal" @onclick:stopPropagation="true">
            <button class="close-btn" @onclick="CloseForgotPasswordModal">✕</button>
            
            <h2>Quên mật khẩu?</h2>
            <div class="step-indicator">
                <div class="step @(forgotPasswordStep == 1 ? "active" : "") @(forgotPasswordStep > 1 ? "completed" : "")">
                    <span class="step-number">1</span>
                    <span class="step-label">Email</span>
                </div>
                <div class="step @(forgotPasswordStep == 2 ? "active" : "") @(forgotPasswordStep > 2 ? "completed" : "")">
                    <span class="step-number">2</span>
                    <span class="step-label">Xác nhận OTP</span>
                </div>
                <div class="step @(forgotPasswordStep == 3 ? "active" : "")">
                    <span class="step-number">3</span>
                    <span class="step-label">Mật khẩu mới</span>
                </div>
            </div>
            
            @if (forgotPasswordStep == 1)
            {
                <EditForm Model="@forgotPasswordModel" OnValidSubmit="HandleSendOtp" OnInvalidSubmit="HandleInvalidForgotPassword" class="forgot-password-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <p class="step-description">Nhập email đã đăng ký để nhận mã OTP</p>
                    
                    <div class="input-wrapper">
                        <InputText @bind-Value="forgotPasswordModel.Username" placeholder="Tên đăng nhập của bạn" />
                        <div class="validation-error"><ValidationMessage For="@(() => forgotPasswordModel.Username)" /></div>
                    </div>

                    <div class="input-wrapper">
                        <InputText @bind-Value="forgotPasswordModel.Email" placeholder="Email của bạn" />
                        <div class="validation-error"><ValidationMessage For="@(() => forgotPasswordModel.Email)" /></div>
                    </div>
                    
                    <button type="submit" class="primary-btn">Gửi mã OTP</button>
                    
                    @if (!string.IsNullOrEmpty(forgotPasswordError))
                    {
                        <div class="error-msg">@forgotPasswordError</div>
                    }
                </EditForm>
            }
            else if (forgotPasswordStep == 2)
            {
                <EditForm Model="@verifyOtpModel" OnValidSubmit="HandleVerifyOtp" OnInvalidSubmit="HandleInvalidVerifyOtp" class="forgot-password-form">
                    <DataAnnotationsValidator />
                    
                    @if (!string.IsNullOrEmpty(forgotPasswordError))
                    {
                        <div class="error-msg">@forgotPasswordError</div>
                    }

                    <p class="step-description">Nhập mã OTP đã được gửi đến email <br /><strong>@verifyOtpModel.Email</strong></p>
                    
                    <div class="input-wrapper">
                        <InputText @bind-Value="verifyOtpModel.OtpCode" placeholder="Mã OTP (6 chữ số)" maxlength="6" />
                        <div class="validation-error"><ValidationMessage For="@(() => verifyOtpModel.OtpCode)" /></div>
                    </div>
                    
                    <div class="otp-timer-wrapper">
                        @if (otpCountdownSeconds > 0)
                        {
                            <span class="otp-timer">Mã sẽ hết hạn sau: <strong>@FormattedCountdown</strong></span>
                        }
                        else
                        {
                            <span class="otp-timer expired">Mã đã hết hạn. <a href="javascript:void(0)" @onclick="HandleSendOtp">Gửi lại mã</a></span>
                        }
                    </div>
                    
                    <div class="button-group">
                        <button type="button" class="secondary-btn" @onclick="GoBackToStep1">Quay lại</button>
                        <button type="submit" class="primary-btn">Xác nhận</button>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(forgotPasswordError))
                    {
                        <div class="error-msg">@forgotPasswordError</div>
                    }
                </EditForm>
            }
            else if (forgotPasswordStep == 3)
            {
                <EditForm Model="@resetPasswordModel" OnValidSubmit="HandleResetPassword" OnInvalidSubmit="HandleInvalidResetPassword" class="forgot-password-form">
                    <DataAnnotationsValidator />
                    
                    @if (!string.IsNullOrEmpty(forgotPasswordError))
                    {
                        <div class="error-msg">@forgotPasswordError</div>
                    }

                    <p class="step-description">Tạo mật khẩu mới cho tài khoản của bạn</p>
                    
                    <div class="input-wrapper">
                        <InputText type="password" @bind-Value="resetPasswordModel.NewPassword" placeholder="Mật khẩu mới" />
                        <div class="validation-error"><ValidationMessage For="@(() => resetPasswordModel.NewPassword)" /></div>
                    </div>
                    
                    <div class="input-wrapper">
                        <InputText type="password" @bind-Value="resetPasswordModel.ConfirmPassword" placeholder="Xác nhận mật khẩu mới" />
                        <div class="validation-error"><ValidationMessage For="@(() => resetPasswordModel.ConfirmPassword)" /></div>
                    </div>
                    
                    <button type="submit" class="primary-btn">Đặt lại mật khẩu</button>
                    
                    @if (!string.IsNullOrEmpty(forgotPasswordError))
                    {
                        <div class="error-msg">@forgotPasswordError</div>
                    }
                    @if (!string.IsNullOrEmpty(forgotPasswordSuccess))
                    {
                        <div class="success-msg">@forgotPasswordSuccess</div>
                    }
                </EditForm>
            }
        </div>
    </div>
}

@code {
    private bool isSignUp = false;
    private bool isRegisterSubmitted = false;
    private bool isLoginSubmitted = false;
    private RegisterModel registerModel = new();
    private LoginModel loginModel = new();
    private string? loginError;
    private string? registerError;
    private string? successMessage;
    private static Login? _instance;
    
    // Forgot password state
    private bool showForgotPassword = false;
    private int forgotPasswordStep = 1;
    private ForgotPasswordModel forgotPasswordModel = new();
    private VerifyOtpModel verifyOtpModel = new();
    private ResetPasswordModel resetPasswordModel = new();
    private string? forgotPasswordError;
    private string? forgotPasswordSuccess;

    // Timer fields
    private int otpCountdownSeconds = 0;
    private System.Threading.Timer? otpTimer;
    private string FormattedCountdown => $"{(otpCountdownSeconds / 60):D2}:{(otpCountdownSeconds % 60):D2}";

    protected override void OnInitialized()
    {
        _instance = this;
        var uri = Navigation.Uri;
        if (uri.Contains("register", StringComparison.OrdinalIgnoreCase))
        {
            isSignUp = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Replace with your ACTUAL Client ID from Google Cloud Console
            var clientId = "1043095171292-c34skmmnadf2oechmavhupcdal8plttc.apps.googleusercontent.com"; 
            await JS.InvokeVoidAsync("googleAuthFunctions.initialize", DotNetObjectReference.Create(this), clientId);
        }
    }

    [JSInvokable]
    public async Task HandleGoogleLogin(string credential)
    {
        try
        {
            var result = await AuthService.GoogleLoginAsync(credential);
            if (result != null)
            {
                if (result.Role == "Admin")
                {
                    Navigation.NavigateTo("/admin");
                }
                else
                {
                    Navigation.NavigateTo("/");
                }
            }
        }
        catch (Exception ex)
        {
            loginError = ex.Message;
            StateHasChanged();
            _ = Task.Run(async () =>
            {
                await Task.Delay(2000);
                loginError = null;
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private void TogglePanel()
    {
        isSignUp = !isSignUp;
        isRegisterSubmitted = false;
        isLoginSubmitted = false;
        loginError = null;
        registerError = null;
    }

    private async Task HandleLogin()
    {
        isLoginSubmitted = true;
        loginError = null;
        try
        {
            var result = await AuthService.LoginAsync(loginModel);
            if (result != null)
            {
                if (result.Role == "Admin")
                {
                    Navigation.NavigateTo("/admin");
                }
                else
                {
                    Navigation.NavigateTo("/");
                }
            }
        }
        catch (Exception ex)
        {
            loginError = ex.Message;
            _ = Task.Run(async () =>
            {
                await Task.Delay(2000);
                loginError = null;
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task HandleRegister()
    {
        isRegisterSubmitted = true;
        registerError = null;
        try
        {
            var result = await AuthService.RegisterAsync(registerModel);
            if (result != null)
            {
                isSignUp = false; // Switch to login
                loginError = null; // Clear error
                successMessage = "Đăng ký thành công! Mời bạn đăng nhập.";
                
                _ = Task.Run(async () =>
                {
                    await Task.Delay(2000);
                    successMessage = null;
                    await InvokeAsync(StateHasChanged);
                });
            }
        }
        catch (Exception ex)
        {
            registerError = ex.Message;
            successMessage = null; // Clear success
            if (ex.Message.Contains("fetch") || ex.Message.Contains("Network Error"))
            {
                registerError = "⚠️ Không thể kết nối tới Backend (Localhost:5001). " + 
                               "Hãy đảm bảo 'docker-compose up' đang chạy hoặc project 'Identity.API' đang chạy ở cổng 5001.";
            }

            _ = Task.Run(async () =>
            {
                await Task.Delay(2000);
                registerError = null;
                await InvokeAsync(StateHasChanged);
            });
        }
    }
    
    // Forgot password methods
    private void OpenForgotPasswordModal()
    {
        showForgotPassword = true;
        forgotPasswordStep = 1;
        forgotPasswordModel = new();
        verifyOtpModel = new();
        resetPasswordModel = new();
        forgotPasswordError = null;
        forgotPasswordSuccess = null;
    }
    
    private void CloseForgotPasswordModal()
    {
        StopOtpTimer();
        showForgotPassword = false;
        forgotPasswordStep = 1;
        forgotPasswordError = null;
        forgotPasswordSuccess = null;
    }
    
    private void StartOtpTimer()
    {
        StopOtpTimer();
        otpCountdownSeconds = 600; // 10 minutes
        otpTimer = new System.Threading.Timer(async _ =>
        {
            if (otpCountdownSeconds > 0)
            {
                otpCountdownSeconds--;
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                StopOtpTimer();
            }
        }, null, 0, 1000);
    }

    private void StopOtpTimer()
    {
        otpTimer?.Dispose();
        otpTimer = null;
    }
    
    private void HandleInvalidForgotPassword()
    {
        forgotPasswordError = "Vui lòng nhập đầy đủ Tên đăng nhập và Email";
        TriggerErrorHide();
    }

    private void HandleInvalidVerifyOtp()
    {
        forgotPasswordError = "Vui lòng nhập đủ 6 số cho mã OTP";
        TriggerErrorHide();
    }

    private void HandleInvalidResetPassword()
    {
        if (string.IsNullOrWhiteSpace(resetPasswordModel.NewPassword) || string.IsNullOrWhiteSpace(resetPasswordModel.ConfirmPassword))
        {
            forgotPasswordError = "Vui lòng nhập đầy đủ thông tin";
        }
        else if (resetPasswordModel.NewPassword != resetPasswordModel.ConfirmPassword)
        {
            forgotPasswordError = "Mật khẩu xác nhận không khớp";
        }
        else if (resetPasswordModel.NewPassword.Length < 6)
        {
            forgotPasswordError = "Mật khẩu phải có ít nhất 6 ký tự";
        }
        else
        {
            forgotPasswordError = "Vui lòng nhập đầy đủ thông tin";
        }
        TriggerErrorHide();
    }

    private void TriggerErrorHide()
    {
        _ = Task.Run(async () =>
        {
            await Task.Delay(1000);
            forgotPasswordError = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task HandleSendOtp()
    {
        forgotPasswordError = null;
        try
        {
            await AuthService.SendOtpAsync(forgotPasswordModel.Username, forgotPasswordModel.Email);
            verifyOtpModel.Email = forgotPasswordModel.Email;
            forgotPasswordStep = 2;
            StartOtpTimer();
        }
        catch (Exception ex)
        {
            forgotPasswordError = ex.Message;
            _ = Task.Run(async () =>
            {
                await Task.Delay(1000);
                forgotPasswordError = null;
                await InvokeAsync(StateHasChanged);
            });
        }
    }
    
    private async Task HandleVerifyOtp()
    {
        forgotPasswordError = null;
        try
        {
            await AuthService.VerifyOtpAsync(verifyOtpModel.Email, verifyOtpModel.OtpCode);
            resetPasswordModel.Email = verifyOtpModel.Email;
            resetPasswordModel.OtpCode = verifyOtpModel.OtpCode;
            StopOtpTimer();
            forgotPasswordStep = 3;
        }
        catch (Exception ex)
        {
            forgotPasswordError = ex.Message;
            _ = Task.Run(async () =>
            {
                await Task.Delay(1000);
                forgotPasswordError = null;
                await InvokeAsync(StateHasChanged);
            });
        }
    }
    
    private async Task HandleResetPassword()
    {
        forgotPasswordError = null;
        forgotPasswordSuccess = null;
        try
        {
            await AuthService.ResetPasswordAsync(
                resetPasswordModel.Email, 
                resetPasswordModel.OtpCode, 
                resetPasswordModel.NewPassword);
            
            forgotPasswordSuccess = "✅ Mật khẩu đã được đặt lại thành công!";
            
            _ = Task.Run(async () =>
            {
                await Task.Delay(2000);
                await InvokeAsync(() =>
                {
                    CloseForgotPasswordModal();
                    StateHasChanged();
                });
            });
        }
        catch (Exception ex)
        {
            forgotPasswordError = ex.Message;
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                forgotPasswordError = null;
                await InvokeAsync(StateHasChanged);
            });
        }
    }
    
    private void GoBackToStep1()
    {
        StopOtpTimer();
        forgotPasswordStep = 1;
        forgotPasswordError = null;
    }
}
