@page "/admin/orders"
@layout AdminLayout
@inherits AuthorizedPageBase
@inject IOrderApiService OrderService
@using Food.Web.Models

<PageTitle>Quản Lý Đơn Đặt Món - FoodOrder Admin</PageTitle>

<div class="admin-orders">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 style="font-weight: 800; color: var(--text-main); font-size: 2rem; margin: 0;"><i class="fa-solid fa-clipboard-list me-2" style="color: #FF6B35;"></i>Quản Lý Đơn Đặt Món</h2>
            <p style="color: var(--text-muted); margin: 0;">Theo dõi và xử lý đơn đặt món từ khách hàng</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-light-premium" @onclick="ExportToCsv" disabled="@(!FilteredOrders.Any())">
                <i class="fa-solid fa-download me-2"></i> Xuất báo cáo (CSV)
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="glass-card p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Đang tải danh sách đơn đặt món...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            @errorMessage
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LoadOrders">Thử lại</button>
        </div>
    }
    else
    {
        <div class="glass-card p-4">
            <div class="d-flex gap-3 mb-4">
                <div class="search-box-premium" style="flex: 1;">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                    <input type="text" placeholder="Tìm theo mã đơn, tên khách..." @bind-value="searchTerm" @bind-value:event="oninput" />
                </div>
                <div class="filter-tabs">
                    <button class="tab-btn @(selectedStatus == "" ? "active" : "")" @onclick='() => selectedStatus = ""'>Tất cả</button>
                    <button class="tab-btn @(selectedStatus == "AwaitingPayment" ? "active" : "")" @onclick='() => selectedStatus = "AwaitingPayment"'>Chờ thanh toán</button>
                    <button class="tab-btn @(selectedStatus == "Pending" ? "active" : "")" @onclick='() => selectedStatus = "Pending"'>Chờ xác nhận</button>
                    <button class="tab-btn @(selectedStatus == "InProgress" ? "active" : "")" @onclick='() => selectedStatus = "InProgress"'>Đang chuẩn bị</button>
                    <button class="tab-btn @(selectedStatus == "Shipped" ? "active" : "")" @onclick='() => selectedStatus = "Shipped"'>Đang giao</button>
                    <button class="tab-btn @(selectedStatus == "Cancelled" ? "active" : "")" @onclick='() => selectedStatus = "Cancelled"'>Đã hủy</button>
                </div>
            </div>

            <div class="table-container">
                <table class="table-fashion">
                    <thead>
                        <tr>
                            <th>Mã đơn đặt món</th>
                            <th>Khách hàng</th>
                            <th>Thời gian đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in FilteredOrders)
                        {
                            <tr>
                                <td><strong style="color: var(--primary-color);">#@o.Id.ToString().Substring(0, 8).ToUpper()</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-small">@(string.IsNullOrEmpty(o.UserName) ? "?" : o.UserName.Substring(0, 1))</div>
                                        <div style="font-weight: 700; color: var(--text-main);">@(string.IsNullOrEmpty(o.UserName) ? "Khách vãng lai" : o.UserName)</div>
                                    </div>
                                </td>
                                <td>
                                    <div style="color: var(--text-main); font-weight: 500;">@o.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div style="font-size: 0.8rem; color: var(--text-muted);">@o.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td class="price-cell">@o.TotalPrice.ToString("N0") ₫</td>
                                <td>
                                    <span class="payment-method-badge">
                                        <i class='@(o.PaymentMethodName == "VNPay" ? "fa-solid fa-credit-card" : "fa-solid fa-money-bill-1") me-1'></i>
                                        @o.PaymentMethodName
                                    </span>
                                </td>
                                <td>
                                    <span class="status-badge-order" style="background: @GetStatusBg(o.OrderStatus); color: @GetStatusColor(o.OrderStatus);">
                                        @TranslateStatus(o.OrderStatus)
                                    </span>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn-action edit" title="Xem chi tiết" @onclick="() => ShowOrderDetails(o)">
                                            <i class="fa-solid fa-eye"></i>
                                        </button>
                                        <button class="btn-action edit" title="Cập nhật trạng thái" @onclick="() => ShowUpdateStatusModal(o)">
                                            <i class="fa-solid fa-rotate"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!FilteredOrders.Any())
                {
                    <div class="text-center py-5">
                        <i class="fa-solid fa-box-open" style="font-size: 3rem; color: var(--text-muted);"></i>
                        <p class="mt-3 text-muted">Không tìm thấy đơn đặt món nào</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Order Details Modal *@
@if (showDetailsModal && selectedOrder != null)
{
    <div class="modal-overlay" @onclick="CloseDetailsModal">
        <div class="modal-dialog-custom large" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <h4><i class="fa-solid fa-receipt me-2"></i>Chi tiết đơn đặt món #@selectedOrder.Id.ToString().Substring(0, 8).ToUpper()</h4>
                <button class="btn-close-custom" @onclick="CloseDetailsModal">&times;</button>
            </div>
            <div class="modal-body-custom">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Tên đăng nhập</h6>
                        <p class="mb-0"><strong>@selectedOrder.UserName</strong></p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Thông tin thanh toán</h6>
                        <p class="mb-0">
                            <strong>@selectedOrder.PaymentMethodName</strong>
                            @if (selectedOrder.PaymentMethodName == "VNPay")
                            {
                                <NavLink href="/admin/payments" class="ms-2 small text-primary"><i class="fa-solid fa-arrow-up-right-from-square"></i> Xem Giao dịch</NavLink>
                            }
                        </p>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Ngày đặt</h6>
                        <p class="mb-0">@selectedOrder.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <h6 class="text-muted mb-3">Món ăn đặt</h6>
                <div class="order-items">
                    @foreach (var item in selectedOrder.OrderItems)
                    {
                        <div class="order-item-row">
                            <div>
                                <strong>@item.ProductName</strong>
                                <div class="text-muted small">Số lượng: @item.Quantity</div>
                            </div>
                            <div class="text-end">
                                <strong>@item.Price.ToString("N0") ₫</strong>
                            </div>
                        </div>
                    }
                </div>

                @if (selectedOrder.CouponAmount > 0)
                {
                    <div class="order-total" style="padding-top: 10px; padding-bottom: 5px; border-top: 1px dashed #eee;">
                        <span>Mã giảm giá (@selectedOrder.CouponCode):</span>
                        <strong class="text-danger">-@selectedOrder.CouponAmount.ToString("N0") ₫</strong>
                    </div>
                }

                <div class="order-total" style='border-top: @(selectedOrder.CouponAmount > 0 ? "none" : "2px solid #f0f0f0")'>
                    <strong>Tổng cộng:</strong>
                    <strong class="text-primary">@selectedOrder.TotalPrice.ToString("N0") ₫</strong>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-secondary-custom" @onclick="CloseDetailsModal">Đóng</button>
            </div>
        </div>
    </div>
}

@* Update Status Modal *@
@if (showStatusModal && orderToUpdate != null)
{
    <div class="modal-overlay" @onclick="CloseStatusModal">
        <div class="modal-dialog-custom" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <h4><i class="fa-solid fa-rotate me-2"></i>Cập nhật trạng thái đơn đặt món</h4>
                <button class="btn-close-custom" @onclick="CloseStatusModal">&times;</button>
            </div>
            <div class="modal-body-custom">
                <p>Đơn đặt món: <strong>#@orderToUpdate.Id.ToString().Substring(0, 8).ToUpper()</strong></p>
                <div class="form-group">
                    <label class="form-label-custom">Trạng thái mới</label>
                    <select class="form-control-custom" @bind="newStatus">
                        <option value="AwaitingPayment">Chờ thanh toán</option>
                        <option value="Pending">Chờ xác nhận</option>
                        <option value="InProgress">Đang chuẩn bị món</option>
                        <option value="Shipped">Đang giao hàng</option>
                        <option value="Cancelled">Đã hủy</option>
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(statusError))
                {
                    <div class="alert alert-danger mt-3">@statusError</div>
                }
            </div>
            <div class="modal-footer-custom">
                <button class="btn btn-secondary-custom" @onclick="CloseStatusModal">Hủy</button>
                <button class="btn btn-primary-custom" @onclick="UpdateOrderStatus" disabled="@isUpdating">
                    @if (isUpdating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Cập nhật
                </button>
            </div>
        </div>
    </div>
}

<style>
    .filter-tabs {
        display: flex;
        background: #f1f3f9;
        padding: 5px;
        border-radius: 14px;
        gap: 5px;
    }

    .tab-btn {
        border: none;
        background: transparent;
        padding: 0.6rem 1.2rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-muted);
        transition: var(--transition);
        cursor: pointer;
    }

    .tab-btn.active {
        background: white;
        color: var(--primary-color);
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .avatar-small {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--primary-light);
        color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
    }

    .status-badge-order {
        padding: 0.4rem 1rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.8rem;
        white-space: nowrap;
        display: inline-block;
    }

    .payment-method-badge {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-main);
        background: #f1f5f9;
        padding: 0.3rem 0.7rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
    }

    .order-items {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .order-item-row {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .order-item-row:last-child {
        border-bottom: none;
    }

    .order-total {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 12px;
        font-size: 1.1rem;
    }

    .modal-dialog-custom.large {
        max-width: 700px;
    }
</style>

@inject IJSRuntime JS

@code {
    private List<OrderDto> orders = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string searchTerm = string.Empty;
    private string selectedStatus = string.Empty;

    // Order details modal
    private bool showDetailsModal = false;
    private OrderDto? selectedOrder = null;

    // Update status modal
    private bool showStatusModal = false;
    private bool isUpdating = false;
    private string statusError = string.Empty;
    private OrderDto? orderToUpdate = null;
    private string newStatus = string.Empty;

    private IEnumerable<OrderDto> FilteredOrders
    {
        get
        {
            if (orders == null) return Enumerable.Empty<OrderDto>();
            
            var filtered = orders.Where(o => o != null);

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                filtered = filtered.Where(o => 
                    (o.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                    (o.UserName != null && o.UserName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                    (o.FullName != null && o.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));
            }

            if (!string.IsNullOrWhiteSpace(selectedStatus))
            {
                filtered = filtered.Where(o => o.OrderStatus == selectedStatus);
            }

            return filtered.OrderByDescending(o => o.CreatedAt);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            Console.WriteLine("[AdminOrders] Starting to load orders...");
            orders = await OrderService.GetOrdersAsync();
            Console.WriteLine($"[AdminOrders] Loaded {orders?.Count ?? 0} orders.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AdminOrders] Error loading orders: {ex}");
            errorMessage = $"Lỗi tải danh sách đơn hàng: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string TranslateStatus(string status) => status switch
    {
        "AwaitingPayment" => "Chờ thanh toán",
        "Pending" => "Chờ xác nhận",
        "InProgress" => "Đang chuẩn bị",
        "Shipped" => "Đang giao",
        "Cancelled" => "Đã hủy",
        _ => status
    };

    private string GetStatusBg(string status) => status switch
    {
        "Shipped" => "#ecfdf5",
        "AwaitingPayment" => "#fef2f2",
        "Pending" => "#fffbeb",
        "InProgress" => "#eff6ff",
        "Cancelled" => "#f3f4f6",
        _ => "#f1f3f9"
    };

    private string GetStatusColor(string status) => status switch
    {
        "Shipped" => "#059669",
        "AwaitingPayment" => "#ef4444",
        "Pending" => "#d97706",
        "InProgress" => "#2563eb",
        "Cancelled" => "#9ca3af",
        _ => "#64748b"
    };

    private void ShowOrderDetails(OrderDto order)
    {
        selectedOrder = order;
        showDetailsModal = true;
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedOrder = null;
    }

    private void ShowUpdateStatusModal(OrderDto order)
    {
        orderToUpdate = order;
        newStatus = order.OrderStatus;
        statusError = string.Empty;
        showStatusModal = true;
    }

    private void CloseStatusModal()
    {
        showStatusModal = false;
        orderToUpdate = null;
        statusError = string.Empty;
    }

    private async Task UpdateOrderStatus()
    {
        if (orderToUpdate == null) return;

        isUpdating = true;
        statusError = string.Empty;

        try
        {
            var success = await OrderService.UpdateOrderStatusAsync(orderToUpdate.Id, newStatus);
            if (success)
            {
                await LoadOrders();
                CloseStatusModal();
            }
            else
            {
                statusError = "Lỗi cập nhật trạng thái";
            }
        }
        catch (Exception ex)
        {
            statusError = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }
    private async Task ExportToCsv()
    {
        var csv = new System.Text.StringBuilder();
        csv.AppendLine("ID,Customer,Date,Total,Status");
        
        foreach (var o in FilteredOrders)
        {
            csv.AppendLine($"{o.Id},{o.UserName},{o.CreatedAt:yyyy-MM-dd HH:mm},{o.TotalPrice},{o.OrderStatus}");
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", "orders_report.csv", "text/csv", base64);
    }

    protected override bool RequireAdminRole => true;
}
