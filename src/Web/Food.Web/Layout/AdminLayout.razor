@inherits LayoutComponentBase

<div class="admin-layout">
    <aside class="sidebar">
        <a href="/admin" class="logo">
            <i class="fa-solid fa-utensils"></i>
            <span>FoodOrder Admin</span>
        </a>

        <div class="nav-group">
            <div class="nav-group-title">Tổng quan</div>
            <nav class="nav-list">
                <NavLink class="nav-link-custom" href="/admin" Match="NavLinkMatch.All">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Bảng điều khiển</span>
                </NavLink>
            </nav>
        </div>

        <div class="nav-group">
            <div class="nav-group-title">Thực Đơn</div>
            <nav class="nav-list">
                <NavLink class="nav-link-custom" href="/admin/products">
                    <i class="fa-solid fa-bowl-food"></i>
                    <span>Món ăn</span>
                </NavLink>
                <NavLink class="nav-link-custom" href="/admin/categories">
                    <i class="fa-solid fa-layer-group"></i>
                    <span>Danh mục thực đơn</span>
                </NavLink>
                <NavLink class="nav-link-custom" href="/admin/inventory">
                    <i class="fa-solid fa-boxes-stacked"></i>
                    <span>Tồn kho nguyên liệu</span>
                </NavLink>
            </nav>
        </div>

        <div class="nav-group">
            <div class="nav-group-title">Đơn Hàng</div>
            <nav class="nav-list">
                <NavLink class="nav-link-custom" href="/admin/orders">
                    <i class="fa-solid fa-clipboard-list"></i>
                    <span>Quản lý đơn</span>
                </NavLink>
                <NavLink class="nav-link-custom" href="/admin/payments">
                    <i class="fa-solid fa-money-check-dollar"></i>
                    <span>Thanh toán</span>
                </NavLink>
            </nav>
        </div>

        <div class="nav-group">
            <div class="nav-group-title">Khuyến Mãi</div>
            <nav class="nav-list">
                <NavLink class="nav-link-custom" href="/admin/coupons">
                    <i class="fa-solid fa-tag"></i>
                    <span>Mã khuyến mãi</span>
                </NavLink>
                <NavLink class="nav-link-custom" href="/admin/banners">
                    <i class="fa-solid fa-images"></i>
                    <span>Banner nhà hàng</span>
                </NavLink>
            </nav>
        </div>

        <div class="nav-group">
            <div class="nav-group-title">Khách Hàng</div>
            <nav class="nav-list">
                <NavLink class="nav-link-custom" href="/admin/reviews">
                    <i class="fa-solid fa-star-half-stroke"></i>
                    <span>Đánh giá món ăn</span>
                </NavLink>
                <NavLink class="nav-link-custom" href="/admin/users">
                    <i class="fa-solid fa-users"></i>
                    <span>Khách hàng</span>
                </NavLink>
            </nav>
        </div>

        @* Removed Sidebar Footer *@
    </aside>

    <main class="main-content">
        <header class="top-bar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass" style="color: #94a3b8;"></i>
                <input type="text" placeholder="Tìm nhanh sản phẩm, đơn hàng..." 
                       @bind="SearchQuery" 
                       @onkeyup="HandleSearch" />
            </div>

            <div class="top-actions">
                <div class="notification-trigger" @onclick="ToggleNotifications">
                    <i class="fa-regular fa-bell" style="font-size: 1.2rem; color: #64748b;"></i>
                    @if (UnreadCount > 0)
                    {
                        <span class="notification-badge">@UnreadCount</span>
                    }

                    @if (showNotifications)
                    {
                        <div class="notification-dropdown" @onclick:stopPropagation>
                            <div class="dropdown-header">
                                <span>Thông báo mới</span>
                                <span class="mark-read" @onclick="MarkAllAsRead">Đánh dấu đã đọc</span>
                            </div>
                            <div class="dropdown-body">
                                @if (!Notifications.Any())
                                {
                                    <div class="p-4 text-center text-muted">Không có thông báo mới</div>
                                }
                                @foreach (var n in Notifications)
                                {
                                    <div class="notification-item @(n.IsNew ? "new" : "")">
                                        <div class="note-icon @n.Type">
                                            <i class="@n.Icon"></i>
                                        </div>
                                        <div class="note-content">
                                            <div class="note-title">@n.Title</div>
                                            <div class="note-desc">@n.Description</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                
                <div class="user-profile">
                    <div class="user-text">
                        <span>Xin chào,</span>
                        <strong>Quản Lý Nhà Hàng</strong>
                    </div>
                    <div class="profile-avatar">
                        <i class="fa-solid fa-user-tie"></i>
                    </div>
                    <button class="logout-btn-admin" @onclick="HandleLogout" title="Đăng xuất">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </button>
                </div>
            </div>
        </header>

        <div class="page-body">
            @Body
        </div>
    </main>
</div>

@implements IDisposable
@inject IOrderApiService OrderService
@inject IReviewApiService ReviewService
@inject IProductApiService ProductService
@inject IAuthService AuthService
@using Food.Web.Models

@code {
    private string SearchQuery { get; set; } = string.Empty;
    private bool showNotifications = false;
    private List<DashboardNote> Notifications = new();
    private int UnreadCount => Notifications.Count(n => n.IsNew);

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadNotifications();
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(SearchQuery))
        {
            Navigation.NavigateTo($"/admin/search?q={Uri.EscapeDataString(SearchQuery)}");
            SearchQuery = string.Empty;
        }
    }

    private async Task LoadNotifications()
    {
        try
        {
            var orders = await OrderService.GetOrdersAsync();
            var reviews = await ReviewService.GetReviewsAsync();
            var products = await ProductService.GetProductsAsync();

            Notifications.Clear();
            
            // New orders (last 24h)
            if (orders != null)
            {
                foreach (var o in orders.Where(o => o != null && o.CreatedAt > DateTime.Now.AddDays(-1)).OrderByDescending(o => o.CreatedAt).Take(3))
                {
                    Notifications.Add(new($"Đơn hàng mới #{o.Id.ToString().Substring(0, 4)}", $"{o.UserName} - {o.TotalPrice:N0}₫", "order", "fa-solid fa-shopping-cart", true));
                }
            }

            // Pending reviews (last 24h or unapproved)
            if (reviews != null)
            {
                foreach (var r in reviews.Where(r => r != null && !r.IsApproved).OrderByDescending(r => r.CreatedAt).Take(2))
                {
                    Notifications.Add(new($"Bình luận chờ duyệt", $"{r.UserName}: {r.Comment}", "review", "fa-solid fa-comment", true));
                }
            }

            // High stock warnings (safe check)
            if (products != null)
            {
                foreach (var p in products.Where(p => p != null && p.StockQuantity > 0 && p.StockQuantity < 5).Take(2))
                {
                    Notifications.Add(new($"Sắp hết hàng: {p.Name}", $"Chỉ còn {p.StockQuantity} sản phẩm", "warn", "fa-solid fa-exclamation-triangle", true));
                }
            }

            StateHasChanged();
        }
        catch { }
    }

    private void ToggleNotifications() => showNotifications = !showNotifications;
    private void MarkAllAsRead() => Notifications.ForEach(n => n.IsNew = false);

    public record DashboardNote(string Title, string Description, string Type, string Icon, bool IsNew = false)
    {
        public bool IsNew { get; set; } = IsNew;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose() { }
}

