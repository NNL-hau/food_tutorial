@using Food.Web.Models
@using Food.Web.Services
@using Food.Web.Helpers
@inject IBasketService BasketService
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="product-card">
    <div class="product-image" @onclick="OpenDetail">
        <img src="@ProductHelpers.GetFirstImageUrl(Product.ImageUrl)" 
             alt="@Product.Name" />
        @if (Product.StockQuantity == 0)
        {
            <div class="badge out-of-stock">Hết món</div>
        }
        else if (IsNew)
        {
            <div class="badge new">New</div>
        }
        
        <div class="product-actions-overlay">
            <button class="action-btn view-detail" @onclick="OpenDetail" @onclick:stopPropagation>
                <i class="fa-solid fa-eye"></i>
                <span>Xem chi tiết</span>
            </button>
            <button class="action-btn add-to-cart" @onclick="HandleAddToCart" @onclick:stopPropagation disabled="@(Product.StockQuantity == 0)">
                <i class="fa-solid fa-cart-plus"></i>
                <span>Chọn món</span>
            </button>
        </div>
    </div>
    
    <div class="product-info" @onclick="OpenDetail">
        <h3 class="product-name">@Product.Name</h3>
        
        <div class="product-price">
            <span class="current-price">@Product.Price.ToString("N0") đ</span>
            <span class="sold-count-mini">Đã bán: @Product.SoldQuantity</span>
        </div>
    </div>
</div>

@if (showDetail)
{
    <div class="product-detail-modal-overlay" @onclick="CloseDetail">
        <div class="product-detail-modal" @onclick:stopPropagation>
            <button class="close-btn" @onclick="CloseDetail">✕</button>
            
            <div class="detail-container">
                <div class="detail-image">
                    <img src="@ProductHelpers.GetFirstImageUrl(Product.ImageUrl)" alt="@Product.Name" />
                </div>
                
                <div class="detail-info">
                    <h2 class="detail-name">@Product.Name</h2>
                    <div class="detail-price">@Product.Price.ToString("N0") đ</div>
                    
                    <div class="detail-meta">
                        <div class="meta-item">
                            <span class="meta-label">Trạng thái:</span>
                            <span class="meta-value @(Product.StockQuantity > 0 ? "in-stock" : "out-of-stock")">
                                @(Product.StockQuantity > 0 ? "Đang phục vụ" : "Tạm hết món")
                            </span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Số lượng còn:</span>
                            <span class="meta-value">@Product.StockQuantity</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Đã phục vụ:</span>
                            <span class="meta-value">@Product.SoldQuantity</span>
                        </div>
                    </div>
                    
                    <div class="detail-description">
                        <h3>Giới thiệu món ăn</h3>
                        <p>@(string.IsNullOrEmpty(Product.Description) ? "Món ăn ngon đậm đà, chuẩn vị nhà hàng, chế biến từ nguyên liệu tươi sạch." : Product.Description)</p>
                    </div>
                    
                    <button class="add-to-cart-big" @onclick="HandleAddToCart" disabled="@(Product.StockQuantity == 0)">
                        <i class="fa-solid fa-cart-plus mr-2"></i>
                        THÊM VÀO GIỎ MÓN
                    </button>
                    
                    @if (showSuccess)
                    {
                        <div class="success-toast">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>Đã thêm vào giỏ món!</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="error-toast">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <div class="error-content">
                                <span>@errorMessage</span>
                                @if (errorMessage.Contains("đăng nhập"))
                                {
                                    <div class="error-links">
                                        <a href="/login">Đăng nhập</a>
                                        <span class="mx-1">|</span>
                                        <a href="/register" class="fw-bold">Đăng ký ngay</a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (showLoginModal)
{
    <div class="auth-modal-overlay" @onclick="() => showLoginModal = false">
        <div class="auth-modal" @onclick:stopPropagation>
            <button class="close-modal" @onclick="() => showLoginModal = false">✕</button>
            <div class="auth-modal-content">
                <div class="auth-icon">
                    <i class="fa-solid fa-user-lock"></i>
                </div>
                <h2>Yêu cầu đăng nhập</h2>
                <p>Vui lòng đăng nhập để có thể thêm món ăn này vào giỏ món của bạn.</p>
                <div class="auth-modal-actions">
                    <button class="btn-primary-auth" @onclick='() => Navigation.NavigateTo("/login")'>Đăng nhập ngay</button>
                    <button class="btn-secondary-auth" @onclick="() => showLoginModal = false">Để sau</button>
                </div>
                <div class="auth-footer">
                    Chưa có tài khoản? <a href="/register">Đăng ký tại đây</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public ProductDto Product { get; set; } = null!;
    
    private bool showDetail = false;
    private bool showSuccess = false;
    private string? errorMessage;
    private bool showLoginModal = false;
    private bool IsNew => (DateTime.Now - Product.CreatedAt).TotalDays <= 30;

    private void OpenDetail()
    {
        Navigation.NavigateTo($"/product/{Product.Id}");
    }
    private void CloseDetail() => showDetail = false;

    private async Task HandleAddToCart()
    {
        errorMessage = null;
        
        if (!await AuthService.IsAuthenticatedAsync())
        {
            showLoginModal = true;
            return;
        }

        await BasketService.AddToBasketAsync(Product);
        showSuccess = true;
        StateHasChanged();
        
        _ = Task.Run(async () =>
        {
            await Task.Delay(2000);
            showSuccess = false;
            await InvokeAsync(StateHasChanged);
        });
    }
}
